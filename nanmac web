import { useEffect } from "react";

const VISITOR_KEY = "nanmac_visitors";
const VISIT_FLAG = "nanmac_visited_session";

export default function VisitorTracker() {
  useEffect(() => {
    const isNew = !sessionStorage.getItem(VISIT_FLAG);
    if (isNew) {
      sessionStorage.setItem(VISIT_FLAG, "true");
      const stored = JSON.parse(localStorage.getItem(VISITOR_KEY) || "{}");
      const today = new Date().toISOString().slice(0, 10);
      stored.total = (stored.total || 0) + 1;
      stored.today = stored.todayDate === today ? (stored.today || 0) + 1 : 1;
      stored.todayDate = today;
      stored.history = stored.history || [];
      const dayEntry = stored.history.find(h => h.date === today);
      if (dayEntry) dayEntry.count += 1;
      else stored.history.push({ date: today, count: 1 });
      if (stored.history.length > 7) stored.history = stored.history.slice(-7);
      localStorage.setItem(VISITOR_KEY, JSON.stringify(stored));
    }
  }, []);
  return null;
}
